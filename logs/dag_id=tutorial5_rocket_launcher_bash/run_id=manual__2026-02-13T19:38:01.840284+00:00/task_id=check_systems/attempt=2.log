{"timestamp":"2026-02-13T19:39:08.273937","level":"info","event":"Running command: ['/usr/bin/bash', '-c', '\\n    python << EOF\\nimport json\\nimport random\\nimport sys\\n\\nlaunch_info_str = \"\"\"{\"name\": \"Falcon 9 Block 5 | Crew-12\", \"status\": \"Success\", \"net\": \"2026-02-13T10:15:56Z\", \"window_start\": \"2026-02-13T10:15:56Z\", \"window_end\": \"2026-02-13T10:15:56Z\", \"rocket\": \"Falcon 9\", \"mission\": \"Crew-12\", \"location\": \"Cape Canaveral SFS, FL, USA\", \"launch_service_provider\": \"SpaceX\"}\"\"\"\\nif not launch_info_str:\\n    print(\"No launch info received\", file=sys.stderr)\\n    sys.exit(1)\\n\\nlaunch_info = json.loads(launch_info_str)\\napi_status = launch_info.get(\\'status\\', \\'Unknown\\')\\n# Accept both \"Go\" and \"Success\" as go conditions\\napi_status_go = api_status in [\"Go\", \"Success\"]\\n\\nsystems = {\\n    \\'navigation\\': random.choice([True, True, True, False]),\\n    \\'communication\\': random.choice([True, True, True, False]),\\n    \\'life_support\\': random.choice([True, True, True, False]),\\n    \\'payload\\': random.choice([True, True, True, False]),\\n    \\'api_status\\': api_status,\\n    \\'api_status_go\\': api_status_go,\\n}\\n\\nall_operational = all([\\n    systems[\\'navigation\\'],\\n    systems[\\'communication\\'],\\n    systems[\\'life_support\\'],\\n    systems[\\'payload\\'],\\n    api_status_go\\n])\\n\\nif not all_operational:\\n    failed = [k for k, v in systems.items() if not v and k not in [\\'api_status\\', \\'api_status_go\\']]\\n    if not api_status_go:\\n        failed.append(f\"API status: {api_status} (expected \\'Go\\' or \\'Success\\')\")\\n    print(f\"SYSTEMS CHECK FAILED: {failed}\", file=sys.stderr)\\n    sys.exit(1)\\n\\nprint(\"SYSTEMS CHECK PASSED\", file=sys.stderr)\\nprint(json.dumps(systems))\\nEOF\\n    ']","logger":"airflow.task.hooks.airflow.providers.standard.hooks.subprocess.SubprocessHook"}
